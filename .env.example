# =============================================================================
# PULSE — Global .env template. Copy to .env and fill in.
# Backend reads via pydantic-settings (looks ../-up for this file).
# Frontend reads via next.config.js (loads ../-up too) for NEXT_PUBLIC_* vars.
# =============================================================================

# LLM (Groq — free tier, OpenAI-compatible API)
GROQ_API_KEY=

# Open-web ingest
NIMBLE_API_KEY=

# ClickHouse Cloud (HTTPS, port 8443)
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Postgres + pgvector (Supabase). Use port 5432, NOT the 6543 pooler.
DATABASE_URL=

# Redis (queue)
REDIS_URL=redis://localhost:6379

# Observability
DD_API_KEY=
DD_SERVICE=pulse
DD_ENV=development
DD_AGENT_HOST=localhost

# Healthcare-vertical action egress (v2)
LUMINAI_API_KEY=

# Platforms
X_BEARER_TOKEN=
X_WEBHOOK_SECRET=
META_APP_SECRET=

# X (Twitter) API v2 — required for the X auto-responder agent.
# Get these at https://developer.x.com/en/portal/dashboard
# Your app must have "Read and Write" permissions AND the access token must be
# regenerated AFTER you enable write access (or posting will 403).
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# X agent runtime config
X_AGENT_TARGET_HANDLE=bruhwhat4110
X_AGENT_KEYWORD=crosby
X_AGENT_POLL_INTERVAL=60
X_AGENT_DRY_RUN=false
# Optional override for Nimble's X search endpoint
# NIMBLE_X_ENDPOINT=https://api.webit.live/api/v1/realtime/serp

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
CLUSTER_SIMILARITY_THRESHOLD=0.82
MERGE_SIMILARITY_THRESHOLD=0.88
BATCH_SIZE=50

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_BRAND_ID=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

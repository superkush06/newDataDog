# =============================================================================
# PULSE — Global .env template. Copy to .env and fill in.
# Backend reads via pydantic-settings (looks ../-up for this file).
# Frontend reads via next.config.js (loads ../-up too) for NEXT_PUBLIC_* vars.
# =============================================================================

# LLM (Groq — free tier, OpenAI-compatible API)
GROQ_API_KEY=

# Open-web ingest
NIMBLE_API_KEY=

# ClickHouse Cloud (HTTPS, port 8443)
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Postgres + pgvector (Supabase). Use port 5432, NOT the 6543 pooler.
DATABASE_URL=

# Redis (queue)
REDIS_URL=redis://localhost:6379

# Observability
DD_API_KEY=
DD_SERVICE=pulse
DD_ENV=development
DD_AGENT_HOST=localhost

# Healthcare-vertical action egress (v2)
LUMINAI_API_KEY=

# Platforms
X_BEARER_TOKEN=
X_WEBHOOK_SECRET=
META_APP_SECRET=

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
CLUSTER_SIMILARITY_THRESHOLD=0.82
MERGE_SIMILARITY_THRESHOLD=0.88
BATCH_SIZE=50

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_BRAND_ID=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
